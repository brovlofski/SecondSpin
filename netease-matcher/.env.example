# Server
PORT=3000
NODE_ENV=development

# NetEase API
# Option A: Self-hosted NeteaseCloudMusicApi proxy (recommended)
#   git clone https://github.com/Binaryify/NeteaseCloudMusicApi && cd NeteaseCloudMusicApi && npm i && node app.js
# Option B: Leave blank to use direct music.163.com API calls
NETEASE_API_BASE_URL=

# MusicBrainz
MUSICBRAINZ_APP_NAME=netease-matcher
MUSICBRAINZ_APP_VERSION=1.0.0
MUSICBRAINZ_CONTACT=your@email.com

# Discogs (optional — only used if enriching release data)
DISCOGS_TOKEN=

# SQLite DB path
DB_PATH=./data/mappings.db

# Matching
MATCH_THRESHOLD=0.75